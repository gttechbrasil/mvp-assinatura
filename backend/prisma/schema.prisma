generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String @id @default(uuid())
  email         String @unique
  password      String

  created_at    DateTime @default(now()) @map("created_at")
  updated_at    DateTime @updatedAt

  @@map("users")
}